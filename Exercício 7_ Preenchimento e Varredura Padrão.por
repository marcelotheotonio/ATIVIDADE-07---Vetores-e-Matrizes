programa {
  funcao inicio() {
    
    inteiro num[4], controle
    
para(controle = 0; controle <= 3; controle++){
escreva("Escreva o valor da posição ", controle, ": ")
leia(num[controle])
}
escreva("Valores digitados: \n")
para(controle = 0; controle <= 3; controle++)
escreva(num[controle], "\t")

   }
  }

