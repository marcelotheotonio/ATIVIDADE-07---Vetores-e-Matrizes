programa {
  funcao inicio() {
    
    cadeia cores[3]

    escreva("Informe a primeira cor: ")
    leia(cores[0])
    escreva("Informe a segunda cor: ")
    leia(cores[1])
    escreva("Informe a terceira cor: ")
    leia(cores[2])

    escreva("Ordem inversa: \n")
    escreva("Primeira cor: ", cores[2], "\n")
    escreva("Segunda cor: ", cores[1], "\n")
    escreva("Terceira cor: ", cores[0], "\n")

  }
}
