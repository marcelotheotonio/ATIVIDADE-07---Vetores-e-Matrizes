programa {
  funcao inicio() {
    
  inteiro num[4]

  escreva("Informe o primeiro número: ")
  leia(num[0])
   escreva("Informe o segundo número: ")
  leia(num[1])
   escreva("Informe o terceiro número: ")
  leia(num[2])
   escreva("Informe o quarto número: ")
  leia(num[3])

se (num[0] == num[3]){
  escreva("Os números no primeiro e último índices, são exatamente iguais!\n")
}
senao{
  escreva("Os números são diferentes!\n")
}

  }
}
